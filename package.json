{
  "name": "live-transcriber",
  "version": "0.1.0",
  "description": "Live meeting transcriber with structured note extraction",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "predev": "npm run rebuild:native",
    "preview": "electron-vite preview",
    "prepreview": "npm run rebuild:native",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "pretest": "npm run rebuild:native:node",
    "test:watch": "vitest",
    "pretest:watch": "npm run rebuild:native:node",
    "test:native": "node scripts/smoke-electron-native.mjs",
    "pretest:native": "npm run rebuild:native",
    "rebuild:native": "node scripts/rebuild-native.mjs electron",
    "rebuild:native:node": "node scripts/rebuild-native.mjs node",
    "postinstall": "node scripts/rebuild-native.mjs electron"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.1",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^11.10.0",
    "sherpa-onnx": "^1.13.3",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "ws": "^8.18.0",
    "zod": "3.24.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
