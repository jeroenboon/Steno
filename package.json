{
  "name": "live-transcriber",
  "version": "0.1.0",
  "description": "Live meeting transcriber with structured note extraction",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "dev": "electron-vite dev",
    "predev": "npm run rebuild:native",
    "dev:debug": "cross-env STENO_DEBUG=1 electron-vite dev",
    "predev:debug": "npm run rebuild:native",
    "preview": "electron-vite preview",
    "prepreview": "npm run rebuild:native",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm test && npm run test:native && npm run audit",
    "audit": "npm audit --audit-level=high",
    "secret-scan": "node scripts/secret-scan.mjs",
    "test": "vitest run",
    "pretest": "npm run rebuild:native:node",
    "test:coverage": "vitest run --coverage",
    "pretest:coverage": "npm run rebuild:native:node",
    "test:watch": "vitest",
    "pretest:watch": "npm run rebuild:native:node",
    "test:native": "node scripts/smoke-electron-native.mjs",
    "pretest:native": "npm run rebuild:native",
    "rebuild:native": "node scripts/rebuild-native.mjs electron",
    "rebuild:native:node": "node scripts/rebuild-native.mjs node",
    "postinstall": "node scripts/rebuild-native.mjs electron",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sherpa-onnx": "^1.13.4",
    "ws": "^8.18.0",
    "zod": "4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "electron": "^42.6.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@emnapi/wasi-threads": "1.2.2"
  }
}
