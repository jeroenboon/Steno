# Pre-push gate: run the fast half of the Definition of Done locally so broken
# code never reaches a PR. The slow, environment-specific steps — build + the
# native ABI smoke test — stay in CI (.github/workflows/ci.yml), which is the
# required check that gates merges into master.
#
# To run the full gate locally before pushing (build + native + audit too):
#   npm run verify
#
# To push despite a failure (rare; e.g. a WIP spike branch): git push --no-verify
echo "pre-push: typecheck · lint · format:check · test"
npm run typecheck && npm run lint && npm run format:check && npm test
